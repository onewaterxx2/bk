---
import "../styles/global.css";
import site from "../data/site.json";
import music from "../data/music.json";
import { withBase } from "../lib/paths";
import { ClientRouter } from "astro:transitions";

const { title = site.title, description = site.subtitle } = Astro.props;
const pageTitle = title === site.title ? site.title : `${title} | ${site.title}`;
const persistentTrack = music.find((track) => track.src);
const playlistJson = JSON.stringify(music.filter((track) => track.src)).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fff8fb" />
    <link rel="icon" href={withBase("images/avatar.svg")} />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    {
      persistentTrack?.src && (
        <audio
          data-site-audio
          src={persistentTrack.src}
          preload="metadata"
          transition:persist
        />
      )
    }
    <script is:inline type="application/json" id="site-playlist" set:html={playlistJson}></script>
    <div class="reading-progress" data-reading-progress></div>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href={withBase()} aria-label="返回首页">
          <span class="brand-mark">水</span>
          <span>{site.title}</span>
        </a>
        <nav class="nav" aria-label="主导航">
          <a href={withBase()}>首页</a>
          <a href={withBase("posts/")}>文章</a>
          <a href={withBase("archive/")}>归档</a>
          <a href={withBase("projects/")}>作品</a>
          <a href={withBase("music/")}>音乐</a>
          <a href={withBase("friends/")}>友链</a>
          <a href={withBase("about/")}>关于</a>
          <button class="icon-button" type="button" data-theme-toggle aria-label="切换深浅色">◐</button>
        </nav>
      </header>
      <slot />
      <footer class="footer">
        <p>© {new Date().getFullYear()} {site.title}. Built with Astro, published by a local blog studio.</p>
      </footer>
    </div>
    <script is:inline src="/bk/scripts/site.js"></script>
  </body>
</html>
