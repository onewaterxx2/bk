---
import Layout from "../../components/Layout.astro";
import { getPublishedPosts } from "../../lib/content";
import { withBase } from "../../lib/paths";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const data = post.data;
---

<Layout title={data.title} description={data.description}>
  <main class="article-shell">
    <article class="article glass">
      <div class="meta">
        <span class="pill">{data.category}</span>
        <time datetime={data.pubDate.toISOString()}>{data.pubDate.toLocaleDateString("zh-CN")}</time>
        {data.readingTime && <span>{data.readingTime}</span>}
      </div>
      <h1>{data.title}</h1>
      <p class="hero-copy">{data.description}</p>
      {data.cover && <img class="article-cover" src={data.cover} alt="" />}
      <div class="tag-list">
        {data.tags.map((tag) => <a href={withBase(`tags/${encodeURIComponent(tag)}/`)}>#{tag}</a>)}
      </div>
      <div class="prose">
        <Content />
      </div>
    </article>
    <aside class="toc glass">
      <strong>目录</strong>
      {headings.filter((heading) => heading.depth <= 3).map((heading) => (
        <a href={`#${heading.slug}`}>{heading.text}</a>
      ))}
    </aside>
  </main>
</Layout>
