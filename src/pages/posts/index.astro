---
import Layout from "../../components/Layout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedPosts, uniqueCategories, uniqueTags } from "../../lib/content";

const posts = await getPublishedPosts();
const categories = uniqueCategories(posts);
const tags = uniqueTags(posts);
const base = import.meta.env.BASE_URL;
---

<Layout title="文章" description="江水博客的全部文章">
  <main class="section">
    <div class="section-title">
      <div>
        <span class="kicker">All Posts</span>
        <h2>文章</h2>
      </div>
      <p>用搜索、分类和标签快速找到想读的内容。</p>
    </div>
    <input class="searchbox" type="search" placeholder="搜索文章..." data-search />
    <div class="tag-list" style="margin-bottom: 22px;">
      {categories.map((category) => <a href={`${base}categories/${encodeURIComponent(category)}/`}>{category}</a>)}
      {tags.map((tag) => <a href={`${base}tags/${encodeURIComponent(tag)}/`}>#{tag}</a>)}
    </div>
    <div class="grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </main>
</Layout>
