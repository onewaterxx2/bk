---
import Layout from "../components/Layout.astro";
import { getPublishedPosts } from "../lib/content";
import { withBase } from "../lib/paths";

const posts = await getPublishedPosts();
---

<Layout title="归档" description="按时间归档的文章">
  <main class="section">
    <div class="section-title">
      <div>
        <span class="kicker">Timeline</span>
        <h2>归档</h2>
      </div>
      <p>按发布时间整理所有文章，适合回看一段时间里的记录。</p>
    </div>
    <div class="archive-list">
      {posts.map((post) => (
        <a class="archive-item" href={withBase(`posts/${post.slug}/`)}>
          <time>{post.data.pubDate.toLocaleDateString("zh-CN")}</time>
          <strong>{post.data.title}</strong>
          <span class="pill">{post.data.category}</span>
        </a>
      ))}
    </div>
  </main>
</Layout>
