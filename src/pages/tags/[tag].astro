---
import Layout from "../../components/Layout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedPosts, uniqueTags } from "../../lib/content";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return uniqueTags(posts).map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props;
const posts = (await getPublishedPosts()).filter((post) => post.data.tags.includes(tag));
---

<Layout title={`标签：${tag}`} description={`标签 ${tag} 下的文章`}>
  <main class="section">
    <div class="section-title">
      <div>
        <span class="kicker">Tag</span>
        <h2>#{tag}</h2>
      </div>
      <p>这个标签下共有 {posts.length} 篇文章。</p>
    </div>
    <div class="grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </main>
</Layout>
