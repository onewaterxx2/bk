---
import Layout from "../../components/Layout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedPosts, uniqueCategories } from "../../lib/content";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return uniqueCategories(posts).map((category) => ({ params: { category }, props: { category } }));
}

const { category } = Astro.props;
const posts = (await getPublishedPosts()).filter((post) => post.data.category === category);
---

<Layout title={`分类：${category}`} description={`分类 ${category} 下的文章`}>
  <main class="section">
    <div class="section-title">
      <div>
        <span class="kicker">Category</span>
        <h2>{category}</h2>
      </div>
      <p>这个分类下共有 {posts.length} 篇文章。</p>
    </div>
    <div class="grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </main>
</Layout>
